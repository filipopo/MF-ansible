[Unit]
Description=Mobile Forces master server list country
After=network.target

[Service]
User={{ server_user }}
WorkingDirectory={{ masterserver_path }}/data
ExecStart={{ masterserver_path }}/WebInterface-Perl-MS-Qt5/util/listcountry.pl
Restart=on-failure
RestartSec=1

[Install]
WantedBy=multi-user.target
